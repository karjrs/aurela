# Build-arg for docker-compose.prod.yml's frontend image. Must be a publicly
# reachable address for the backend — the user's browser queries it directly,
# not the Next.js server — so changing it requires rebuilding the frontend
# image, not just restarting the container.
NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://api.your-domain.example/api/graphql

# Postgres credentials for docker-compose.prod.yml's postgres service.
# Also used to build the backend's DATABASE_URL — no need to set that separately.
POSTGRES_USER=aurela
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aurela
