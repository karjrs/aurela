{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "codegen": "NODE_OPTIONS='--import tsx/esm' graphql-codegen --config codegen.ts",
    "codegen:watch": "NODE_OPTIONS='--import tsx/esm' graphql-codegen --config codegen.ts --watch",
    "predev": "pnpm codegen",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm codegen",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "pretypecheck": "pnpm codegen",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm codegen",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "helmet": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-resolvers": "^6.0.2",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
