{
  "name": "aurela",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "pnpm --dir frontend dev",
    "dev:backend": "pnpm --dir backend dev",
    "build:frontend": "pnpm --dir frontend build",
    "build:backend": "pnpm --dir backend build",
    "lint:frontend": "biome lint ./frontend",
    "lint:backend": "biome lint ./backend",
    "typecheck:frontend": "pnpm --dir frontend typecheck",
    "typecheck:backend": "pnpm --dir backend typecheck",
    "typecheck": "pnpm typecheck:frontend && pnpm typecheck:backend",
    "test": "pnpm test:frontend && pnpm test:backend",
    "test:frontend": "pnpm --dir frontend test",
    "test:backend": "pnpm --dir backend test",
    "test:e2e": "pnpm --dir frontend test:e2e",
    "check": "pnpm lint:frontend && pnpm lint:backend && pnpm typecheck && pnpm test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
